GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west1

# Cloud SQL (real) — get host from: terraform output cloud_sql_public_ip
CLOUD_SQL_HOST=your-cloud-sql-public-ip
CLOUD_SQL_PORT=5432
CLOUD_SQL_USER=rag
CLOUD_SQL_PASSWORD=your-cloud-sql-password
CLOUD_SQL_DB=regional

# GCS (real) — get bucket from: terraform output documents_bucket
GCS_DOCUMENTS_BUCKET=your-gcs-bucket-name
GCS_RAW_PREFIX=raw/
GCS_PROCESSED_PREFIX=processed/

# BigQuery (real)
BIGQUERY_DATASET=global_metrics

# Vertex AI — get endpoint from: terraform output vector_search_endpoint_id
VERTEX_AI_LOCATION=europe-west1
VERTEX_AI_INDEX_ENDPOINT=projects/your-project-id/locations/europe-west1/indexEndpoints/your-endpoint-id
VERTEX_AI_DEPLOYED_INDEX_ID=rag_poc_index_v1
EMBEDDING_MODEL=text-embedding-004
