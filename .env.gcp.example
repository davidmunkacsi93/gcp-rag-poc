export GCP_PROJECT_ID=your-gcp-project-id
export GCP_REGION=europe-west1

# Cloud SQL (real) — get host from: terraform output cloud_sql_public_ip
export CLOUD_SQL_HOST=your-cloud-sql-public-ip
export CLOUD_SQL_PORT=5432
export CLOUD_SQL_USER=rag
export CLOUD_SQL_PASSWORD=your-cloud-sql-password
export CLOUD_SQL_DB=regional

# GCS (real) — get bucket from: terraform output documents_bucket
export GCS_DOCUMENTS_BUCKET=your-gcs-bucket-name
export GCS_RAW_PREFIX=raw/
export GCS_PROCESSED_PREFIX=processed/

# BigQuery (real)
export BIGQUERY_DATASET=global_metrics

# Vertex AI — get values from: terraform output
export VERTEX_AI_LOCATION=europe-west1
export VERTEX_AI_INDEX_ID=projects/your-project-id/locations/europe-west1/indexes/your-index-id
export VERTEX_AI_INDEX_ENDPOINT=projects/your-project-id/locations/europe-west1/indexEndpoints/your-endpoint-id
export VERTEX_AI_DEPLOYED_INDEX_ID=rag_poc_index_v1
export EMBEDDING_MODEL=text-embedding-004

# Generation
export GENERATION_STUB=false
export GENERATION_MODEL=gemini-2.0-flash-001
export GENERATION_MAX_CONTEXT_TOKENS=8000
export GENERATION_MAX_OUTPUT_TOKENS=1024
export GENERATION_TEMPERATURE=0.2
export GENERATION_CITATION_STYLE=inline
