# PostgreSQL (local Docker substitute for Cloud SQL)
export POSTGRES_USER=rag
export POSTGRES_PASSWORD=rag
export POSTGRES_DB=regional
export POSTGRES_HOST=localhost
export POSTGRES_PORT=5432

# GCS emulator (fake-gcs-server)
export GCS_EMULATOR_HOST=http://localhost:4443
export STORAGE_EMULATOR_HOST=localhost:4443
export GCS_DOCUMENTS_BUCKET=rag-poc-documents-dev
export GCS_RAW_PREFIX=raw/
export GCS_PROCESSED_PREFIX=processed/

# BigQuery emulator
export BIGQUERY_EMULATOR_HOST=http://localhost:9050
export BIGQUERY_DATASET=global_metrics

# Firestore emulator
export FIRESTORE_EMULATOR_HOST=localhost:8090

# Vertex AI — stub embedder used locally, no real endpoint needed
export VERTEX_AI_LOCATION=europe-west1
export VERTEX_AI_INDEX_ENDPOINT=
export VERTEX_AI_DEPLOYED_INDEX_ID=your-deployed-index-id
export EMBEDDING_MODEL=stub

# Generation — stub used locally, no Gemini call
export GENERATION_STUB=true
export GENERATION_MODEL=gemini-2.0-flash-001
export GENERATION_MAX_CONTEXT_TOKENS=8000
export GENERATION_MAX_OUTPUT_TOKENS=1024
export GENERATION_TEMPERATURE=0.2
export GENERATION_CITATION_STYLE=inline

# Service URLs (for running services outside docker-compose)
