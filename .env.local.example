GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west1

# PostgreSQL (local Docker substitute for Cloud SQL)
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=regional
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# GCS emulator (fake-gcs-server)
GCS_EMULATOR_HOST=http://localhost:4443
STORAGE_EMULATOR_HOST=localhost:4443
GCS_DOCUMENTS_BUCKET=rag-poc-documents-dev
GCS_RAW_PREFIX=raw/
GCS_PROCESSED_PREFIX=processed/

# BigQuery emulator
BIGQUERY_EMULATOR_HOST=http://localhost:9050
BIGQUERY_DATASET=global_metrics

# Firestore emulator
FIRESTORE_EMULATOR_HOST=localhost:8090

# Vertex AI — stub embedder used locally, no real endpoint needed
VERTEX_AI_LOCATION=europe-west1
VERTEX_AI_INDEX_ENDPOINT=
VERTEX_AI_DEPLOYED_INDEX_ID=your-deployed-index-id
EMBEDDING_MODEL=stub
